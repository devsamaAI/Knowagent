# Copy this file to .env and fill in your values
# cp .env.example .env
# NEVER commit .env to git — it contains your secrets!

# ── Required ──────────────────────────────────────────────────────────────

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional (defaults are fine for local dev) ────────────────────────────

# PostgreSQL connection string from Neon (set this on Koyeb for production)
# If not set, falls back to SQLite locally
# DATABASE_URL=postgresql://user:password@host/dbname

DB_PATH=pocket_agent.db
MAX_CONTENT_LENGTH=8000
